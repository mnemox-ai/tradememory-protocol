# MT5 Account Configuration
# Copy this file to .env and fill in your credentials

# MT5 Demo Account
MT5_LOGIN=your_login_here
MT5_PASSWORD=your_password_here
MT5_SERVER=YourBroker-Server

# MT5 Terminal Path (auto-detect if not set)
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# TradeMemory API Endpoint
TRADEMEMORY_API=http://localhost:8000

# Sync interval (seconds)
SYNC_INTERVAL=60

# Daily reflection output directory
REFLECTION_OUTPUT_DIR=reflections

# Discord Webhook (optional — get notified when trades sync and daily reports generate)
# Create at: Discord Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=

# Anthropic API Key (for LLM-based features: evolution engine, replay, reflections)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
