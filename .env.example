# TradeMemory Protocol — Environment Variables
# Copy this file to .env and fill in your values

# ── Core ───────────────────────────────────────────
# TradeMemory API endpoint (for REST API mode)
TRADEMEMORY_API=http://localhost:8000

# ── Optional ───────────────────────────────────────
# Anthropic API Key (for evolution engine, replay, reflections)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Daily reflection output directory
REFLECTION_OUTPUT_DIR=reflections

# Discord Webhook (trade sync + daily report notifications)
# Create at: Discord Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=

# ── MT5 Integration (optional) ─────────────────────
# Only needed if syncing trades from MetaTrader 5
MT5_LOGIN=your_login_here
MT5_PASSWORD=your_password_here
MT5_SERVER=YourBroker-Server

# MT5 Terminal Path (auto-detect if not set)
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# Sync interval in seconds
SYNC_INTERVAL=60
